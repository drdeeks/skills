# =============================================================================
# USB-Hemlock — Optional environment overrides
#
# Copy to ~/.config/usb-compute-automation/env  OR  source before running
# menu.sh. EVERY variable here is OPTIONAL — the path resolver (CL-026 /
# SPEC-T05) defaults to USB-first whenever a USB device is detected, falling
# back to HOST only when explicitly told to or when no USB is present.
#
# ── Targeting semantics ──────────────────────────────────────────────────────
# Each TARGET variable accepts one of three string values:
#
#   default   — let the path resolver decide (USB if mounted, HOST otherwise)
#   usb       — force the action to operate inside the USB persistence
#   host      — force the action to operate on the host filesystem (will
#               prompt for "HOST" confirmation per SPEC-T05 when destructive)
#
# String over numeric (-1/0/1) is intentional: `STARTUP_TARGET=usb` reads
# itself; `STARTUP_TARGET=1` requires you to remember the convention.
#
# Per-function overrides are honored AFTER the global default. So:
#   TARGET_DEFAULT=usb
#   STARTUP_TARGET=host       # only the startup wizard goes host-side
# results in: every other action stays USB, startup wizard writes to host.
# =============================================================================


# ── CL-030: Top-level install mode ──────────────────────────────────────────
# This is the BIG switch the boot-time selector sets (or you set here to skip
# the prompt). Two values:
#
#   usb   → Alias manager, enhanced bash profile, antivirus logs/quarantine,
#           and everything the menu installs lives on USB persistence under
#           <usb-mount>/usb-hemlock/etc/uca/. Initial bridge setup (boot
#           sector, udev rules, source-line in host ~/.bashrc) is the ONLY
#           time the host filesystem is written; after that the host is just
#           compute power. Cleaner (clean-local.sh) is BLOCKED in this mode.
#   host  → Local enhancements only — bash profile/aliases/cleanup land in
#           $XDG_CONFIG_HOME/usb-compute-automation. USB never touched.
#
# Unset → silent USB detect; auto-host if none, prompt if USB found.
# UCA_MODE=usb
# UCA_MODE=host

# ── Global default ──────────────────────────────────────────────────────────
# When set, applies to every <COMPONENT>_TARGET that isn't overridden below.
# Unset / "default" → USB-first per CL-026.
TARGET_DEFAULT=default


# ── Per-component target overrides (all optional) ───────────────────────────
# Each maps to a menu.sh component. Uncomment + change only what you need.

# USB_SETUP_TARGET=default        # option 1  — Ventoy installer
# USBCTL_TARGET=default           # option 2  — unified CLI
# ALIAS_TARGET=host               # option 3  — aliases live in $HOME
# SSH_TARGET=host                 # option 4  — ~/.ssh/hosts_usb on host
# SYSMAN_TARGET=host              # option 5  — host system checks
# AUTOMOUNT_TARGET=host           # option 6  — udev/systemd on host
# ESSENTIALS_TARGET=default       # option 7  — toolchain (USB persist by default)
# STARTUP_TARGET=usb              # option 8  — boot scripts → USB rc.local
# PERSISTENCE_TARGET=usb          # option 9  — always USB
# BASH_PROFILE_TARGET=host        # option 10 — ~/.bashrc on host
# DEVICE_SETUP_TARGET=default     # option 11 — auto-detect
# DEVICE_CONFIG_TARGET=host       # option 12 — per-device profiles on host
# VALIDATION_TARGET=default       # option 13 — runs everywhere it can
# DIAG_TARGET=host                # option 14 — host system diag
# LOGS_TARGET=host                # option 15 — /tmp + /var/log
# PATHS_TARGET=default            # option 16 — config + env
# ACCESS_TARGET=default           # option 17 — chroot/QEMU/SSH into USB
# HEMLOCK_TARGET=container        # option 19 — container by definition


# ── USB primary persistence override ─────────────────────────────────────────
# By default the resolver auto-discovers (_uca_primary_persistence) the
# active primary on the mounted USB. Override only if you have multiple
# USBs with the same layout and need to pin a specific one.
# UCA_PRIMARY_PERSISTENCE=/media/<user>/<label>/persistence/ubuntu-persistence.dat


# ── Persistence slot mapping (Ventoy + multi-volume) ────────────────────────
# This is INFORMATIONAL — Ventoy itself owns ISO→persistence mapping via
# ventoy.json (see references/ventoy-setup.md). Numeric slot indices below
# mirror the order ventoy.json lists them, so you can refer to slots by
# number in scripts.
#
# To map an ISO to a specific slot, edit <USB>/ventoy/ventoy.json:
#   {
#     "persistence": [
#       { "image": "/ubuntu-24.04-desktop.iso", "backend": "/persistence/ubuntu-persistence.dat" },
#       { "image": "/kali-2026-live.iso",       "backend": "/persistence/hemlock.dat"            },
#       { "image": "/parrot-os.iso",            "backend": "/persistence/models.dat"             }
#     ]
#   }
# Then slot 1 = ubuntu, slot 2 = hemlock, slot 3 = models — Ventoy reads them
# in order on boot. No parallel numbering scheme inside USB-Hemlock needed.
#
# UCA_PERSISTENCE_SLOT_DEFAULT=1


# ── Other useful toggles ────────────────────────────────────────────────────

# DRY_RUN=true                    # preview every action; no mutations
# HEMLOCK_ENABLED=true            # same as --hemlock flag
# LOG_LEVEL=INFO                  # DEBUG | INFO | WARN | ERROR
# LOG_FILE=/tmp/usb-hemlock.log
# UCA_ENVIRONMENT=usb-mounted     # override env detection (usb-boot/usb-mounted/native)
# SELECTED_DEVICE=/dev/sdc        # skip auto-detect


# ── Hemlock container paths (only honored INSIDE the container) ─────────────
# These are read by hemlock-runtime/scripts/helpers.sh. The Dockerfile sets
# sane defaults; override only when running outside the standard image.
# AGENTS_DIR=/data/agents
# CREWS_DIR=/data/crews
# IMPORTS_DIR=/data/imports
# EXPORTS_DIR=/data/exports
# HERMES_HOME=/runtime
# RUNTIME_ROOT=/data

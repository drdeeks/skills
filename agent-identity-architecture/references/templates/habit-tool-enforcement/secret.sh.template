#!/usr/bin/env bash
# secret.sh.template - Template for auto-fix

set -euo pipefail

WORKSPACE="${WORKSPACE}"
SECRETS_DIR="$WORKSPACE/.secrets"

usage() {
    echo "Usage: $0 {get|set|list|delete} <key> [value]"
    echo "  get <key>     - Retrieve secret value"
    echo "  set <key> <value> - Store secret (encrypted)"
    echo "  list          - List all secret keys"
    echo "  delete <key>  - Delete a secret"
    exit 1
}

mkdir -p "$SECRETS_DIR"
chmod 700 "$SECRETS_DIR"

ENCRYPTION_KEY_FILE="$SECRETS_DIR/.encryption_key"
if [[ ! -f "$ENCRYPTION_KEY_FILE" ]]; then
    openssl rand -base64 32 > "$ENCRYPTION_KEY_FILE"
    chmod 600 "$ENCRYPTION_KEY_FILE"
fi

ENCRYPTION_KEY=$(cat "$ENCRYPTION_KEY_FILE")

encrypt() {
    echo -n "$1" | openssl enc -aes-256-cbc -a -salt -pbkdf2 -pass pass:"$ENCRYPTION_KEY"
}

decrypt() {
    echo -n "$1" | openssl enc -aes-256-cbc -d -a -salt -pbkdf2 -pass pass:"$ENCRYPTION_KEY" 2>/dev/null
}

case "${1:-}" in
    get)
        [[ -z "${2:-}" ]] && usage
        key="$2"
        secret_file="$SECRETS_DIR/$key.enc"
        if [[ -f "$secret_file" ]]; then
            decrypt "$(cat "$secret_file")"
        else
            echo "ERROR: Secret '$key' not found" >&2
            exit 1
        fi
        ;;
    set)
        [[ -z "${2:-}" || -z "${3:-}" ]] && usage
        key="$2"
        value="$3"
        encrypted=$(encrypt "$value")
        echo "$encrypted" > "$SECRETS_DIR/$key.enc"
        chmod 600 "$SECRETS_DIR/$key.enc"
        echo "Secret '$key' stored."
        ;;
    list)
        for f in "$SECRETS_DIR"/*.enc; do
            [[ -f "$f" ]] && basename "$f" .enc
        done
        ;;
    delete)
        [[ -z "${2:-}" ]] && usage
        key="$2"
        rm -f "$SECRETS_DIR/$key.enc"
        echo "Secret '$key' deleted."
        ;;
    *)
        usage
        ;;
esac
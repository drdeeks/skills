{
  "description": "Functional tests for crew-heartbeat.sh",
  "tests": [
    {
      "description": "Shows help with --help flag",
      "args": ["--help"],
      "expect": {
        "returncode": 0,
        "stdout_contains": ["Crew Heartbeat", "crew-id", "WORKSPACE_ROOT"],
        "stderr_empty": true
      }
    },
    {
      "description": "Shows help when missing crew-id",
      "args": [],
      "expect": {
        "returncode": 0,
        "stdout_contains": ["Crew Heartbeat", "Usage:", "crew-id"]
      }
    }
  ]
}
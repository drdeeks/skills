{
  "description": "Functional tests for install-identity-skill.py",
  "tests": [
    {
      "description": "Shows help with --help flag",
      "args": ["--help"],
      "expect": {
        "returncode": 0,
        "stdout_contains": ["install-identity-skill", "workspace", "Example"],
        "stderr_empty": false
      }
    },
    {
      "description": "Shows help when missing workspace argument",
      "args": [],
      "expect": {
        "returncode": 0,
        "stdout_contains": ["install-identity-skill", "Usage:", "workspace", "Example"]
      }
    }
  ]
}
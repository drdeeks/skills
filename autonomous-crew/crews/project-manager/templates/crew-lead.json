        "text": "=Review all completed subtasks and provide final integration guidance for: {{ $json.task }}",
        "options": {
          "systemMessage": "You are the Lead Architect performing final review.\n\nReview all completed work from your specialist agents and:\n1. Verify all subtasks are complete\n2. Check integration points\n3. Identify any gaps or issues\n4. Provide final recommendations\n5. Create deployment checklist\n\nOutput format:\n{\n  \"review\": \"overall assessment\",\n  \"integrationStatus\": \"ready|needs-work\",\n  \"recommendations\": [\"list of recommendations\"],\n  \"deploymentChecklist\": [\"checklist items\"]\n}",
          "maxIterations": 10

    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst subtasks = input.subtasks || [];\nconst currentIndex = input.currentSubtaskIndex || 0;\n\nif (currentIndex >= subtasks.length) {\n  return [{ json: { ...input, allSubtasksComplete: true } }];\n}\n\nconst currentSubtask = subtasks[currentIndex];\n\nreturn [{\n  json: {\n    ...input,\n    currentSubtask: currentSubtask,\n    allSubtasksComplete: false\n  }\n}];"
      },
      "id": "cd9fad5c-b999-4a33-a798-acd70b2bbb2e",
      "name": "Get Current Subtask",

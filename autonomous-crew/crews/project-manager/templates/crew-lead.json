    {
      "parameters": {
        "jsCode": "const items = $input.all();\nif (items.length === 0) return [];\n\nconst firstItem = items[0].json;\nconst agentOutput = firstItem.output || \"{}\";\n\nlet result;\ntry {\n  const jsonMatch = agentOutput.match(/\\{[\\s\\S]*\\}/);\n  result = jsonMatch ? JSON.parse(jsonMatch[0]) : { implementation: agentOutput, status: \"complete\" };\n} catch (e) {\n  result = { implementation: agentOutput, status: \"complete\" };\n}\n\nreturn [{\n  json: {\n    ...firstItem,\n    agentResult: result,\n    subtaskComplete: true\n  }\n}];"
      },

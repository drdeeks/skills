    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst leadOutput = input.output;\n\nlet plan;\ntry {\n  const jsonMatch = leadOutput.match(/\\{[\\s\\S]*\\}/);\n  if (jsonMatch) {\n    plan = JSON.parse(jsonMatch[0]);\n  } else {\n    plan = { plan: leadOutput, subtasks: [], integrationStrategy: \"Sequential execution\" };\n  }\n} catch (e) {\n  plan = { plan: leadOutput, subtasks: [], integrationStrategy: \"Sequential execution\" };\n}\n\nreturn [\n  {\n    json: {\n      ...input,\n      plan: plan.plan || leadOutput,\n      subtasks: plan.subtasks || [],\n      integrationStrategy: plan.integrationStrategy || \"Sequential execution\",\n      planningComplete: true,\n      currentSubtaskIndex: 0\n    }\n  }\n];"
      },
      "id": "8c5e677c-facd-419b-8630-eb64bcfea0fe",
      "name": "Parse Plan",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1040,
        1936
      ]
    },
    {

    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst agent = input.currentSubtask?.agent || \"backend\";\n\nreturn [{\n  json: {\n    ...input,\n    targetAgent: agent\n  }\n}];"
      },
